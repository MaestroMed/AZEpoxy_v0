# ══════════════════════════════════════════════════════════════════════════
# AZ Époxy — variables d'environnement
# Copier en .env.local puis remplir : cp .env.example .env.local
# En production (Vercel) : Project Settings → Environment Variables.
# ══════════════════════════════════════════════════════════════════════════

# ─── Base de données (Neon Postgres) ─────────────────────────────────────────
# URL de connexion Postgres. Provisionnée par l'intégration Vercel ↔ Neon,
# récupérable en local via `vercel env pull` ou depuis console.neon.tech.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── Auth admin (backoffice /admin) ──────────────────────────────────────────
# Email du compte admin unique (comparé au login).
ADMIN_EMAIL=contact@azepoxy.fr
# Hash bcrypt du mot de passe admin — à générer via `npm run admin:hash`.
ADMIN_PASSWORD_HASH=
# Secret de signature des JWT de session (≥ 32 caractères) — générer via
# `openssl rand -base64 48`.
ADMIN_JWT_SECRET=
# Levier de révocation "déconnexion partout" (optionnel, défaut "1"). Bumper
# cette valeur (→ "2", "3"…) invalide instantanément toutes les sessions
# ouvertes — à utiliser si le secret fuit ou en cas d'appareil perdu.
ADMIN_SESSION_VERSION=1

# ─── Anti-abus (formulaires publics) ─────────────────────────────────────────
# Cloudflare Turnstile (gratuit, RGPD-friendly) : créer un site sur
# https://dash.cloudflare.com/?to=/:account/turnstile. Si les deux clés
# manquent, les formulaires sautent la vérification (dev uniquement).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Clé secrète Turnstile (vérification serveur des tokens).
TURNSTILE_SECRET_KEY=
# Upstash Redis (rate limiting des API publiques) : https://upstash.com.
# Sans ces deux variables, fallback in-memory qui se vide à chaque cold
# start — NE PAS déployer en prod sans elles.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Emails (Resend + relance QStash) ────────────────────────────────────────
# Clé API Resend (envoi des leads + notifications admin) : resend.com/api-keys.
RESEND_API_KEY=
# Expéditeur des emails. Sans cette variable : sandbox "onboarding@resend.dev"
# (n'envoie qu'au propriétaire du compte). En prod : vérifier le domaine
# azepoxy.fr chez Resend puis mettre p. ex. "AZ Époxy <contact@azepoxy.fr>".
RESEND_FROM=
# Upstash QStash (email de relance ~1h après un devis abandonné) :
# https://upstash.com/docs/qstash. Sans token, l'abandon est juste loggé.
QSTASH_TOKEN=
# Clés de vérification des signatures QStash (console Upstash → QStash).
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── SEO & crons ─────────────────────────────────────────────────────────────
# URL canonique du site (sans slash final). Utilisée par les crons QA,
# IndexNow et les actions admin SEO. Défaut code : https://www.azepoxy.fr.
NEXT_PUBLIC_SITE_URL=https://www.azepoxy.fr
# Secret des crons Vercel (/api/cron/qa-villes, /api/cron/indexnow) et du
# healthcheck détaillé — envoyé en header `Authorization: Bearer <secret>`.
# Vercel l'ajoute automatiquement quand il est défini dans le projet.
CRON_SECRET=
# Clé IndexNow (ping Bing/Yandex/Naver). Valeur aléatoire à dupliquer dans
# public/{clé}.txt pour la vérification de propriété du domaine.
INDEXNOW_KEY=

# ─── Analytics ───────────────────────────────────────────────────────────────
# Measurement ID Google Analytics 4 (admin GA4 → Flux de données).
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── Observabilité (Sentry) ──────────────────────────────────────────────────
# DSN Sentry (sentry.io → Project Settings → Client Keys). Sans DSN, aucun
# code d'observabilité n'est chargé. NEXT_PUBLIC_ est prioritaire ; SENTRY_DSN
# (server-only) est accepté en alternative.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ─── Intégrations ────────────────────────────────────────────────────────────
# Slug d'event Cal.com pour la prise de rendez-vous, ex. "azepoxy/visite-
# atelier". Sans valeur, /rendez-vous bascule sur un CTA téléphone.
NEXT_PUBLIC_CALCOM_LINK=
# Webhook lead (CRM / Zapier / Make / Notion…) : tout endpoint HTTPS qui
# accepte un POST JSON. Reçoit chaque nouveau lead.
LEAD_WEBHOOK_URL=
# Si défini, chaque POST est signé HMAC SHA-256 (header X-AZEpoxy-Signature)
# pour que le consommateur vérifie l'authenticité.
LEAD_WEBHOOK_SECRET=
# Google Places API (New) + Place ID de la fiche Google Business — utilisés
# par le healthcheck (/api/healthz) pour signaler l'intégration avis.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
