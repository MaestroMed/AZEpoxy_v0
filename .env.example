# ─── Email (Resend) ──────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Analytics ───────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── Sanity CMS (Phase 2) ────────────────────────────────────────────────────
# Create a free project at https://www.sanity.io/manage. Without these the
# site falls back to the hardcoded data shipped with the repo and `/studio`
# returns an error.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Server-only token with write permission. Used by `npm run sanity:seed` and
# (Phase 3) by the lead-write pipeline. Generate from sanity.io/manage → API.
SANITY_WRITE_TOKEN=

# Webhook secret for /api/revalidate. Set the same value in the Sanity webhook
# UI so signed payloads can refresh ISR tags after each content edit.
SANITY_REVALIDATE_SECRET=
