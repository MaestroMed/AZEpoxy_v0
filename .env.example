# ─── Email (Resend) ──────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Analytics ───────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── Sanity CMS (Phase 2) ────────────────────────────────────────────────────
# Create a free project at https://www.sanity.io/manage. Without these the
# site falls back to the hardcoded data shipped with the repo and `/studio`
# returns an error.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Server-only token with write permission. Used by `npm run sanity:seed` and
# (Phase 3) by the lead-write pipeline. Generate from sanity.io/manage → API.
SANITY_WRITE_TOKEN=

# Webhook secret for /api/revalidate. Set the same value in the Sanity webhook
# UI so signed payloads can refresh ISR tags after each content edit.
SANITY_REVALIDATE_SECRET=

# ─── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Free tier: https://upstash.com/. Without these the rate limit falls back to
# an in-memory Map that resets on every cold start — DO NOT ship production
# without these.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Anti-bot (Cloudflare Turnstile) ─────────────────────────────────────────
# Free, GDPR-clean. Create a site at https://dash.cloudflare.com/?to=/:account/turnstile.
# When both keys are missing the forms skip verification.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Lead webhook (CRM / Zapier / Make / Notion / HubSpot …) ─────────────────
# Any HTTPS endpoint that accepts POST JSON. When _SECRET is set we add an
# HMAC SHA-256 signature in the X-AZEpoxy-Signature header so the consumer
# can verify authenticity.
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=

# ─── Abandoned-devis recovery (Upstash QStash) ───────────────────────────────
# https://upstash.com/docs/qstash. Schedules a recovery email ~1h after an
# abandoned wizard. Without QStash the abandon beacon is logged only.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── Cal.com booking (Phase 4) ───────────────────────────────────────────────
# Your event type slug, e.g. "azepoxy/visite-atelier". When missing, the
# /rendez-vous page falls back to a phone-first CTA.
NEXT_PUBLIC_CALCOM_LINK=

# ─── Google Places reviews sync (Phase 4) ────────────────────────────────────
# Places API (New) key + your Google Business Place ID. Trigger the sync
# daily from Vercel Cron with the shared secret in the x-sync-secret header.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_REVIEWS_SYNC_SECRET=
